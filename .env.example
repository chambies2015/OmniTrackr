# Database
DATABASE_URL=postgresql://user:password@localhost:5432/streamtracker
# For local development with SQLite: DATABASE_URL=sqlite:///./movies.db

# Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32

# Server (optional, defaults work for local)
PORT=8000
HOST=0.0.0.0

# External API Keys (optional)
# OMDB_API_KEY=your-omdb-api-key
# RAWG_API_KEY=your-rawg-api-key
# iTunes Search API does not require an API key (free and open)
# Open Library API does not require an API key (free and open)

# Google AdSense (optional, has default value)
# ADSENSE_PUBLISHER_ID=pub-7271682066779719
